# Core model selection. Requires the matching provider integration package.
MODEL=openai:gpt-4.1-mini
TEMPERATURE=0

# Optional: LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=focus-agent

# Optional: durable short-term memory and long-term memory store
# Leave empty to use in-memory state for local development.
DATABASE_URI=postgresql://postgres:postgres@localhost:5442/postgres?sslmode=disable

# Optional: Agent Server / LangSmith Deployment URL.
# When set, BranchService prefers exact thread copy through the server API.
LANGGRAPH_API_URL=http://localhost:2024

# Local branch lineage metadata store
BRANCH_DB_PATH=.focus_agent/branches.sqlite3

# Artifact output directory for the demo tool
ARTIFACT_DIR=.focus_agent/artifacts

# Authentication defaults for local development only.
# Disable demo token issuance and use a strong secret in any shared or public environment.
AUTH_ENABLED=true
AUTH_DEMO_TOKENS_ENABLED=true
AUTH_JWT_SECRET=change-me-in-shared-env
AUTH_JWT_ISSUER=focus-agent
AUTH_ACCESS_TOKEN_TTL_SECONDS=28800

# CORS. Leave empty to disable the CORS middleware (same-origin only).
# Provide a comma-separated list of allowed origins for cross-origin browser clients.
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Rate limiting. Disabled by default; enable in shared environments.
# Chat endpoints (which trigger LLM calls) use the stricter chat-specific limit.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_CHAT_PER_MINUTE=20
