# Copy this file to:
# .focus_agent/local.env
#
# That local file is git-ignored, so it stays on your machine and does not get pushed.
#
# Use this file for local credentials and provider endpoints only.
# Model selection, helper_model, provider metadata, and the visible model list live in:
# .focus_agent/models.toml
#
# Built-in tool enablement and runtime limits live in:
# .focus_agent/tools.toml
#
# Generated artifacts default to:
# .focus_agent/artifacts/
# Override with ARTIFACT_DIR only when you intentionally want a different local output path.
#
# Process environment variables still win over this file.
# You can override the file path with FOCUS_AGENT_LOCAL_ENV_FILE.
#
# Leave DATABASE_URI unset when you use the local startup commands (`make api`,
# `make dev`, `make serve`, `make serve-dev`, or `make serve-prod`). They manage
# a local PostgreSQL for you,
# inject DATABASE_URI into the API process automatically, stop it when the service
# exits, and keep the repo-local Postgres data directory for the next run.
# That auto-managed path requires PostgreSQL tools like `initdb`, `pg_ctl`,
# `createdb`, and `psql` to be available on your PATH.
# Set DATABASE_URI only when you intentionally want to use an existing PostgreSQL;
# explicit DATABASE_URI values are preserved and not replaced by local startup.

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me-locally
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=replace-me-locally
TAVILY_API_KEY=replace-me-locally
TEMPERATURE=0

# Agent role routing is preview-first and disabled by default.
# Executor falls back to MODEL / .focus_agent/models.toml default; planning,
# critique, memory, and skill roles fall back to HELPER_MODEL when unset.
# AGENT_ROLE_ROUTING_ENABLED=false
# AGENT_ROLE_MAX_PARALLEL_RUNS=3
# AGENT_ROLE_ORCHESTRATOR_MODEL=
# AGENT_ROLE_PLANNER_MODEL=
# AGENT_ROLE_EXECUTOR_MODEL=
# AGENT_ROLE_CRITIC_MODEL=
# AGENT_ROLE_MEMORY_MODEL=
# AGENT_ROLE_SKILL_MODEL=

# Agent governance automation is feature-flagged.
# AGENT_MEMORY_CURATOR_ENABLED=false
# AGENT_MEMORY_AUTO_PROMOTE_ON_MERGE=true
# AGENT_TOOL_ROUTER_ENABLED=false
# AGENT_TOOL_ROUTER_ENFORCE=true
# AGENT_DELEGATION_ENABLED=false
# AGENT_DELEGATION_ENFORCE=false
# AGENT_MODEL_ROUTER_ENABLED=false
# AGENT_MODEL_ROUTER_MODE=observe
# AGENT_SELF_REPAIR_ENABLED=false
# AGENT_REVIEW_QUEUE_ENABLED=false
# AGENT_CONTEXT_ENGINEERING_V2_ENABLED=false
# AGENT_CONTEXT_ARTIFACTIZE_LONG_OBSERVATIONS=false
# AGENT_CONTEXT_ROLE_VIEWS_ENABLED=false
# AGENT_CONTEXT_TOKENIZER_MODE=chars_fallback
# AGENT_CONTEXT_ARTIFACT_MIN_CHARS=12000

# ARTIFACT_DIR=.focus_agent/artifacts
# DATABASE_URI=postgresql://user:pass@host:5432/focus_agent
# WEB_APP_DEV_SERVER_URL=http://127.0.0.1:5173/app
