# Copy this file to:
# .focus_agent/local.env
#
# That local file is git-ignored, so it stays on your machine and does not get pushed.
#
# Use this file for local credentials and provider endpoints only.
# Model selection, helper_model, provider metadata, and the visible model list live in:
# .focus_agent/models.toml
#
# Built-in tool enablement and runtime limits live in:
# .focus_agent/tools.toml
#
# Generated artifacts default to:
# .focus_agent/artifacts/
# Override with ARTIFACT_DIR only when you intentionally want a different local output path.
#
# Process environment variables still win over this file.
# You can override the file path with FOCUS_AGENT_LOCAL_ENV_FILE.

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-me-locally
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=replace-me-locally
TAVILY_API_KEY=replace-me-locally
TEMPERATURE=0
# ARTIFACT_DIR=.focus_agent/artifacts
# WEB_APP_DEV_SERVER_URL=http://127.0.0.1:5173/app
